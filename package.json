{
  "name": "lingua-muse",
  "version": "6.6.0",
  "description": "Lingua Muse - Language Atelier",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "author": "Lingua Muse",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.linguamuse.app",
    "productName": "Lingua Muse",
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "portable": {
      "artifactName": "LinguaMuse_v6.6.exe"
    }
  }
